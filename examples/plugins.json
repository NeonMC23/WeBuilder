{
  "$schema": "../schemas/build.schema.json",
  "meta": {
    "title": "WeBuilder — Plugin demonstration",
    "theme": "neon:cyber",
    "lang": "en",
    "description": "Two plugin libraries loaded with separate namespaces"
  },
  "assets": [],
  "pages": [
    {
      "path": "index.html",
      "components": [
        {
          "type": "main",
          "variant": "default",
          "children": [
            {
              "type": "section",
              "variant": "default",
              "content": {
                "label": "Plugins WeBuilder"
              },
              "children": [
                {
                  "type": "container",
                  "variant": "wide",
                  "children": [
                    {
                      "type": "neon:heading",
                      "variant": "glitch",
                      "class": [
                        "neon:gradient-text",
                        "mb-12"
                      ],
                      "content": {
                        "text": "Plugin System"
                      }
                    },
                    {
                      "type": "grid",
                      "variant": "two",
                      "children": [
                        {
                          "type": "neon:card",
                          "variant": "default",
                          "class": [
                            "neon:glow",
                            "md:neon:glow-strong"
                          ],
                          "content": {
                            "title": "Namespace neon",
                            "text": "This component, theme, and utility classes come from plugins/neon.json."
                          },
                          "children": [
                            {
                              "type": "neon:button",
                              "variant": "cyan",
                              "id": "neon-action",
                              "class": [
                                "mt-4"
                              ],
                              "content": {
                                "text": "Activate"
                              },
                              "events": {
                                "click": "console.log('Neon plugin component', el);"
                              }
                            }
                          ]
                        },
                        {
                          "type": "commerce:card",
                          "variant": "default-right",
                          "class": [
                            "commerce:product-hover",
                            "hover:commerce:sale-ring"
                          ],
                          "content": {
                            "title": "Namespaced product",
                            "text": "The commerce:card component does not conflict with neon:card.",
                            "price": "$49.00",
                            "badge": "PLUGIN"
                          },
                          "children": [
                            {
                              "type": "stack",
                              "variant": "horizontal",
                              "class": [
                                "mt-4"
                              ],
                              "children": [
                                {
                                  "type": "commerce:quantity",
                                  "variant": "default",
                                  "content": {
                                    "name": "quantity",
                                    "max": "10"
                                  }
                                },
                                {
                                  "type": "commerce:cart-button",
                                  "variant": "primary",
                                  "content": {
                                    "text": "Add to cart",
                                    "product_id": "plugin-demo"
                                  },
                                  "events": {
                                    "cart:add": "console.log('Product added:', event.detail.productId);"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "neon:terminal",
                      "variant": "default",
                      "class": [
                        "mt-12",
                        "neon:scanlines"
                      ],
                      "content": {
                        "title": "Build command",
                        "copy_text": "Copy",
                        "lines": [
                          {
                            "prompt": "$",
                            "command": "python build.py --input examples/plugins.json --output ./build-plugins --plugin plugins/neon.json plugins/commerce.json --preview"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
