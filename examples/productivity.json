{
  "meta": {
    "title": "WeBuilder 1.1 — Productivité",
    "theme": "nord",
    "lang": "fr",
    "description": "Démonstration des utilitaires ouverts et composants interactifs"
  },
  "assets": [],
  "pages": [
    {
      "path": "index.html",
      "components": [
        {
          "type": "main",
          "variant": "default",
          "children": [
            {
              "type": "section",
              "variant": "fullscreen",
              "content": {"label": "Démonstration de productivité"},
              "children": [
                {
                  "type": "container",
                  "variant": "wide",
                  "children": [
                    {
                      "type": "heading",
                      "variant": "display",
                      "class": ["max-w-[12ch]", "mb-7.5"],
                      "content": {"text": "Construire plus vite."}
                    },
                    {
                      "type": "text",
                      "variant": "lead",
                      "class": ["max-w-[62ch]", "mb-12"],
                      "content": {
                        "text": "Les valeurs numériques, arbitraires, responsive et interactives sont générées à partir des classes réellement utilisées."
                      }
                    },
                    {
                      "type": "grid",
                      "variant": "auto",
                      "class": ["gap-7.5"],
                      "children": [
                        {
                          "type": "surface",
                          "variant": "raised",
                          "class": ["p-[clamp(1rem,_4vw,_2.5rem)]", "md:hover:-mt-[4px]", "transition"],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {"text": "Contrôles natifs"}
                            },
                            {
                              "type": "switch",
                              "variant": "default",
                              "class": ["mb-4"],
                              "content": {
                                "name": "notifications",
                                "label": "Activer les notifications",
                                "checked": true
                              }
                            },
                            {
                              "type": "range",
                              "variant": "default",
                              "content": {
                                "name": "intensity",
                                "label": "Intensité",
                                "min": "0",
                                "max": "10",
                                "value": "7"
                              }
                            }
                          ]
                        },
                        {
                          "type": "surface",
                          "variant": "raised",
                          "class": ["p-7.5"],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {"text": "Interactions prêtes"}
                            },
                            {
                              "type": "rating",
                              "variant": "interactive",
                              "class": ["mb-6"],
                              "content": {
                                "name": "score",
                                "label": "Note du produit",
                                "value": "4"
                              },
                              "events": {
                                "ratingchange": "console.log('Nouvelle note :', event.detail.value);"
                              }
                            },
                            {
                              "type": "copy-button",
                              "variant": "default",
                              "content": {
                                "label": "Copier la commande",
                                "text": "python build.py --preview --watch",
                                "success_text": "Commande copiée !"
                              }
                            }
                          ]
                        },
                        {
                          "type": "surface",
                          "variant": "glass",
                          "class": ["p-7.5"],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {"text": "Compte à rebours"}
                            },
                            {
                              "type": "countdown",
                              "variant": "default",
                              "content": {"datetime": "2027-01-01T00:00:00+01:00"}
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "banner",
                      "variant": "info",
                      "class": ["mt-16", "rounded-[18px]"],
                      "content": {
                        "title": "Utilitaire sans limite prédéfinie",
                        "text": "Cette bannière utilise mt-16 et rounded-[18px]."
                      },
                      "children": [
                        {
                          "type": "popover",
                          "variant": "default",
                          "content": {
                            "label": "En savoir plus",
                            "title": "CSS à la demande",
                            "text": "Seules les règles présentes dans build.json sont générées."
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "back-to-top",
          "variant": "default",
          "content": {"label": "Revenir en haut"}
        }
      ]
    }
  ]
}
