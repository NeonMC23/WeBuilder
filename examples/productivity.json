{
  "$schema": "../schemas/build.schema.json",
  "meta": {
    "title": "WeBuilder 1.3 — Productivity",
    "theme": "nord",
    "lang": "en",
    "description": "Open-ended utilities and interactive components demonstration"
  },
  "assets": [],
  "pages": [
    {
      "path": "index.html",
      "components": [
        {
          "type": "main",
          "variant": "default",
          "children": [
            {
              "type": "section",
              "variant": "fullscreen",
              "content": {
                "label": "Productivity demonstration"
              },
              "children": [
                {
                  "type": "container",
                  "variant": "wide",
                  "children": [
                    {
                      "type": "heading",
                      "variant": "display",
                      "class": [
                        "max-w-[12ch]",
                        "mb-7.5"
                      ],
                      "content": {
                        "text": "Build faster."
                      }
                    },
                    {
                      "type": "text",
                      "variant": "lead",
                      "class": [
                        "max-w-[62ch]",
                        "mb-12"
                      ],
                      "content": {
                        "text": "Numeric, arbitrary, responsive, and interactive rules are generated from the classes actually used."
                      }
                    },
                    {
                      "type": "grid",
                      "variant": "auto",
                      "class": [
                        "gap-7.5"
                      ],
                      "children": [
                        {
                          "type": "surface",
                          "variant": "raised",
                          "class": [
                            "p-[clamp(1rem,_4vw,_2.5rem)]",
                            "md:hover:-mt-[4px]",
                            "transition"
                          ],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {
                                "text": "Native controls"
                              }
                            },
                            {
                              "type": "switch",
                              "variant": "default",
                              "class": [
                                "mb-4"
                              ],
                              "content": {
                                "name": "notifications",
                                "label": "Enable notifications",
                                "checked": true
                              }
                            },
                            {
                              "type": "range",
                              "variant": "default",
                              "content": {
                                "name": "intensity",
                                "label": "Intensity",
                                "min": "0",
                                "max": "10",
                                "value": "7"
                              }
                            }
                          ]
                        },
                        {
                          "type": "surface",
                          "variant": "raised",
                          "class": [
                            "p-7.5"
                          ],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {
                                "text": "Ready-made interactions"
                              }
                            },
                            {
                              "type": "rating",
                              "variant": "interactive",
                              "class": [
                                "mb-6"
                              ],
                              "content": {
                                "name": "score",
                                "label": "Product rating",
                                "value": "4"
                              },
                              "events": {
                                "ratingchange": "console.log('New rating:', event.detail.value);"
                              }
                            },
                            {
                              "type": "copy-button",
                              "variant": "default",
                              "content": {
                                "label": "Copy command",
                                "text": "python build.py --preview --watch",
                                "success_text": "Command copied!"
                              }
                            }
                          ]
                        },
                        {
                          "type": "surface",
                          "variant": "glass",
                          "class": [
                            "p-7.5"
                          ],
                          "children": [
                            {
                              "type": "heading",
                              "variant": "h3",
                              "content": {
                                "text": "Countdown"
                              }
                            },
                            {
                              "type": "countdown",
                              "variant": "default",
                              "content": {
                                "datetime": "2027-01-01T00:00:00+01:00"
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "banner",
                      "variant": "info",
                      "class": [
                        "mt-16",
                        "rounded-[18px]"
                      ],
                      "content": {
                        "title": "Utility without a predefined scale",
                        "text": "This banner uses mt-16 and rounded-[18px]."
                      },
                      "children": [
                        {
                          "type": "popover",
                          "variant": "default",
                          "content": {
                            "label": "Learn more",
                            "title": "On-demand CSS",
                            "text": "Only rules referenced by build.json are generated."
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "back-to-top",
          "variant": "default",
          "content": {
            "label": "Back to top"
          }
        }
      ]
    }
  ]
}
