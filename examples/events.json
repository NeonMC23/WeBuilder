{
  "$schema": "../schemas/build.schema.json",
  "meta": {
    "title": "WeBuilder events",
    "theme": "dark",
    "lang": "en"
  },
  "assets": [],
  "pages": [
    {
      "path": "index.html",
      "components": [
        {
          "type": "container",
          "variant": "default",
          "class": [
            "py-6"
          ],
          "children": [
            {
              "type": "button",
              "variant": "primary",
              "id": "counter-button",
              "content": {
                "text": "Counter: 0"
              },
              "events": {
                "click": "const count = Number(el.dataset.count || 0) + 1; el.dataset.count = String(count); el.textContent = `Counter: ${count}`;",
                "mouseenter": "console.log('Pointer entered', el.dataset.id);"
              }
            }
          ]
        }
      ]
    },
    {
      "path": "second.html",
      "components": [
        {
          "type": "button",
          "variant": "danger",
          "id": "counter-button",
          "content": {
            "text": "Same ID, different page"
          },
          "events": {
            "click": "console.log('Targeting remains isolated to second.html');"
          }
        }
      ]
    }
  ]
}
