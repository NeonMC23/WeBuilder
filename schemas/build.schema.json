{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webuilder.dev/schemas/build.schema.json",
  "title": "WeBuilder site configuration",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "meta": {"$ref": "#/$defs/meta"},
    "assets": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true,
      "default": []
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/page"}
    }
  },
  "additionalProperties": true,
  "$defs": {
    "meta": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "theme": {"type": "string", "minLength": 1},
        "lang": {"type": "string", "minLength": 2},
        "description": {"type": "string"},
        "author": {"type": "string"},
        "robots": {"type": "string"},
        "favicon": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "page": {
      "type": "object",
      "required": ["path", "components"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^[^/\\\\](?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).*\\.html?$"
        },
        "meta": {"$ref": "#/$defs/meta"},
        "components": {
          "type": "array",
          "items": {"$ref": "#/$defs/component"}
        }
      },
      "additionalProperties": true
    },
    "component": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "variant": {"type": "string", "minLength": 1},
        "id": {"type": ["string", "integer"]},
        "class": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "content": {"type": "object"},
        "events": {
          "type": "object",
          "propertyNames": {"pattern": "^[A-Za-z][A-Za-z0-9:_-]*$"},
          "additionalProperties": {"type": "string"}
        },
        "children": {
          "type": "array",
          "items": {"$ref": "#/$defs/component"}
        }
      },
      "additionalProperties": true
    }
  }
}
