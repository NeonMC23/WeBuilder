{
  "$schema": "./schemas/build.schema.json",
  "meta": {
    "title": "WeBuilder — Demo website",
    "theme": "dark",
    "lang": "en",
    "description": "A modular website generated with WeBuilder",
    "author": "WeBuilder Team",
    "favicon": "assets/favicon.svg"
  },
  "assets": [
    "images/logo.svg",
    "images/landscape.svg",
    "assets/favicon.svg"
  ],
  "pages": [
    {
      "path": "index.html",
      "components": [
        {
          "type": "header",
          "variant": "primary",
          "class": [
            "sticky",
            "shadow"
          ],
          "content": {
            "title": "WeBuilder",
            "logo": "/assets/images/logo.svg",
            "nav": [
              {
                "text": "Home",
                "href": "/index.html"
              },
              {
                "text": "Contact",
                "href": "/contact.html"
              },
              {
                "text": "Guide",
                "href": "/guide.html"
              }
            ]
          }
        },
        {
          "type": "hero",
          "variant": "centered",
          "content": {
            "eyebrow": "Static site generator",
            "title": "Build a complete website from JSON",
            "text": "Multiple pages, themes, nested components, JavaScript events, and assets—with no client-side framework."
          },
          "children": [
            {
              "type": "button",
              "variant": "primary",
              "id": "discover",
              "content": {
                "text": "Explore"
              },
              "events": {
                "click": "document.querySelector('[data-id=features]')?.scrollIntoView({ behavior: 'smooth' });"
              }
            },
            {
              "type": "link",
              "variant": "button",
              "content": {
                "text": "Contact us",
                "href": "/contact.html"
              }
            }
          ],
          "class": [
            "py-24",
            "md:py-32"
          ]
        },
        {
          "type": "section",
          "variant": "default",
          "id": "features",
          "content": {
            "label": "Features"
          },
          "children": [
            {
              "type": "container",
              "variant": "default",
              "children": [
                {
                  "type": "stats",
                  "variant": "grid",
                  "class": [
                    "mb-4"
                  ],
                  "content": {
                    "items": [
                      {
                        "label": "Components",
                        "value": "82",
                        "detail": "Included library"
                      },
                      {
                        "label": "Variants",
                        "value": "191",
                        "detail": "Ready to use"
                      },
                      {
                        "label": "Runtime dependencies",
                        "value": "0",
                        "detail": "JavaScript vanilla"
                      }
                    ]
                  }
                },
                {
                  "type": "grid",
                  "variant": "three",
                  "children": [
                    {
                      "type": "card",
                      "variant": "elevated",
                      "content": {
                        "title": "Modular HTML",
                        "text": "Mustache templates, loops, inverted sections, and child components."
                      },
                      "class": [
                        "p-7.5",
                        "md:hover:-mt-[3px]"
                      ]
                    },
                    {
                      "type": "card",
                      "variant": "elevated",
                      "content": {
                        "title": "Organized CSS",
                        "text": "One theme, utility classes, and a separate file for every used variant."
                      }
                    },
                    {
                      "type": "card",
                      "variant": "elevated",
                      "content": {
                        "title": "Precisely targeted JavaScript",
                        "text": "Declarative events become addEventListener calls targeted to a unique instance."
                      }
                    }
                  ]
                },
                {
                  "type": "alert",
                  "variant": "info",
                  "class": [
                    "mt-4"
                  ],
                  "content": {
                    "title": "Tip",
                    "text": "Edit build.json, then run WeBuilder with --watch.",
                    "dismissible": true
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "footer",
          "variant": "simple",
          "content": {
            "year": "2026",
            "name": "WeBuilder",
            "text": "Generated with Python.",
            "links": [
              {
                "text": "Home",
                "href": "/index.html"
              },
              {
                "text": "Contact",
                "href": "/contact.html"
              }
            ]
          }
        }
      ]
    },
    {
      "path": "contact.html",
      "meta": {
        "title": "Contact — WeBuilder",
        "description": "Contact form generated with WeBuilder components"
      },
      "components": [
        {
          "type": "header",
          "variant": "minimal",
          "class": [
            "sticky"
          ],
          "content": {
            "title": "WeBuilder",
            "nav": [
              {
                "text": "Home",
                "href": "/index.html"
              },
              {
                "text": "Contact",
                "href": "/contact.html"
              },
              {
                "text": "Guide",
                "href": "/guide.html"
              }
            ]
          }
        },
        {
          "type": "section",
          "variant": "default",
          "content": {
            "label": "Contact form"
          },
          "children": [
            {
              "type": "container",
              "variant": "default",
              "children": [
                {
                  "type": "breadcrumb",
                  "variant": "default",
                  "class": [
                    "mb-4"
                  ],
                  "content": {
                    "items": [
                      {
                        "text": "Home",
                        "href": "/index.html"
                      },
                      {
                        "text": "Contact",
                        "href": ""
                      }
                    ]
                  }
                },
                {
                  "type": "form",
                  "variant": "default",
                  "id": "contact-form",
                  "content": {
                    "action": "#",
                    "method": "post"
                  },
                  "events": {
                    "submit": "event.preventDefault(); console.log('Form submitted', new FormData(el)); alert('Thank you. This demo form was submitted locally.');"
                  },
                  "children": [
                    {
                      "type": "input",
                      "variant": "text",
                      "content": {
                        "label": "Name",
                        "name": "name",
                        "placeholder": "Your name",
                        "required": true
                      }
                    },
                    {
                      "type": "input",
                      "variant": "email",
                      "content": {
                        "label": "E-mail",
                        "name": "email",
                        "placeholder": "you@example.com",
                        "required": true,
                        "help": "Your email address will not be shared."
                      }
                    },
                    {
                      "type": "select",
                      "variant": "default",
                      "content": {
                        "label": "Subject",
                        "name": "subject",
                        "options": [
                          {
                            "text": "Question",
                            "value": "question",
                            "selected": true
                          },
                          {
                            "text": "Project",
                            "value": "project"
                          },
                          {
                            "text": "Support",
                            "value": "support"
                          }
                        ]
                      }
                    },
                    {
                      "type": "textarea",
                      "variant": "default",
                      "content": {
                        "label": "Message",
                        "name": "message",
                        "placeholder": "Tell us about your project…",
                        "required": true
                      }
                    },
                    {
                      "type": "checkbox",
                      "variant": "default",
                      "content": {
                        "label": "I agree to be contacted",
                        "name": "consent",
                        "required": true
                      }
                    },
                    {
                      "type": "button",
                      "variant": "primary",
                      "id": "send-contact",
                      "class": [
                        "mt-2"
                      ],
                      "content": {
                        "text": "Send",
                        "button_type": "submit"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "footer",
          "variant": "simple",
          "content": {
            "name": "WeBuilder",
            "year": "2026",
            "text": "See you soon."
          }
        }
      ]
    },
    {
      "path": "guide.html",
      "meta": {
        "title": "Guide — WeBuilder"
      },
      "components": [
        {
          "type": "header",
          "variant": "minimal",
          "content": {
            "title": "WeBuilder",
            "nav": [
              {
                "text": "Home",
                "href": "/index.html"
              },
              {
                "text": "Contact",
                "href": "/contact.html"
              },
              {
                "text": "Guide",
                "href": "/guide.html"
              }
            ]
          }
        },
        {
          "type": "section",
          "variant": "muted",
          "content": {
            "label": "Quick guide"
          },
          "children": [
            {
              "type": "container",
              "variant": "default",
              "children": [
                {
                  "type": "callout",
                  "variant": "tip",
                  "class": [
                    "mb-4"
                  ],
                  "content": {
                    "title": "Getting started",
                    "text": "Run the command from the webuilder directory."
                  }
                },
                {
                  "type": "code-block",
                  "variant": "default",
                  "class": [
                    "mb-4"
                  ],
                  "content": {
                    "language": "Terminal",
                    "code": "python build.py --input build.json --output ./build"
                  }
                },
                {
                  "type": "accordion",
                  "variant": "default",
                  "content": {
                    "items": [
                      {
                        "title": "Where are components defined?",
                        "text": "In library.json under the components key."
                      },
                      {
                        "title": "How do I add an event?",
                        "text": "Add an events object to the component in build.json."
                      },
                      {
                        "title": "How do I enable dark mode?",
                        "text": "Set meta.theme to dark."
                      }
                    ]
                  }
                },
                {
                  "type": "details",
                  "variant": "default",
                  "class": [
                    "mt-4"
                  ],
                  "content": {
                    "title": "Show technical details",
                    "text": "The Mustache engine uses the Python standard library, while watch mode uses watchdog."
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "footer",
          "variant": "columns",
          "content": {
            "name": "WeBuilder",
            "text": "Demo documentation.",
            "columns": [
              {
                "title": "Pages",
                "links": [
                  {
                    "text": "Home",
                    "href": "/index.html"
                  },
                  {
                    "text": "Contact",
                    "href": "/contact.html"
                  }
                ]
              },
              {
                "title": "Resources",
                "links": [
                  {
                    "text": "README",
                    "href": "#"
                  },
                  {
                    "text": "library.json",
                    "href": "#"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
